<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="https://w3id.org/ontostart/mie/"
         xmlns:sulo="https://w3id.org/sulo/"
         xmlns:pro="https://w3id.org/ontostart/pro/"
         xmlns="https://w3id.org/ontostart/mie/">

<owl:Ontology rdf:about="https://w3id.org/ontostart/mie">
  <owl:imports rdf:resource="https://w3id.org/sulo"/>
  <owl:imports rdf:resource="https://w3id.org/ontostart/pro"/>
</owl:Ontology>

<owl:Class rdf:about="SCT_RoutineGynecologicExamination">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Process"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="https://w3id.org/sulo/hasDirectPart"/>
      <owl:onClass rdf:resource="SCT_PhysicalExamination"/>
      <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="https://w3id.org/sulo/hasDirectPart"/>
      <owl:onClass rdf:resource="SCT_ClinicalDocumentation"/>
      <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:label xml:lang="en">routine gynecologic examination</rdfs:label>
</owl:Class>

<owl:Class rdf:about="SCT_PhysicalExamination">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Process"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="https://w3id.org/sulo/hasDirectPart"/>
      <owl:onClass rdf:resource="SCT_ManualBreastExamination"/>
      <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:label xml:lang="en">physical examination</rdfs:label>
</owl:Class>

<owl:Class rdf:about="SCT_ClinicalDocumentation">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Process"/>
  <rdfs:label xml:lang="en">clinical documentation</rdfs:label>
</owl:Class>

<owl:Class rdf:about="SCT_ManualBreastExamination">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Process"/>
  <rdfs:label xml:lang="en">manual breast examination</rdfs:label>
</owl:Class>

<owl:Class rdf:about="SCT_UltrasonographyOfLeftBreast">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Process"/>
  <rdfs:label xml:lang="en">ultrasonography of left breast</rdfs:label>
</owl:Class>

<owl:Class rdf:about="SCT_DiagnosticAssessment">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Process"/>
  <rdfs:label xml:lang="en">diagnostic assessment</rdfs:label>
</owl:Class>

<owl:Class rdf:about="SCT_CoreNeedleBiopsyOfBreast">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Process"/>
  <rdfs:subClassOf rdf:resource="https://w3id.org/ontostart/pro/TransformationProcess"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="https://w3id.org/sulo/hasParticipant"/>
      <owl:someValuesFrom>
        <owl:Class>
          <owl:intersectionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="RadiologistRole"/>
            <owl:Restriction>
              <owl:onProperty rdf:resource="https://w3id.org/sulo/isFeatureOf"/>
              <owl:someValuesFrom rdf:resource="Person"/>
            </owl:Restriction>
          </owl:intersectionOf>
        </owl:Class>
      </owl:someValuesFrom>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="https://w3id.org/sulo/hasParticipant"/>
      <owl:someValuesFrom>
        <owl:Class>
          <owl:intersectionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/ontostart/pro/EmergingRole"/>
            <owl:Restriction>
              <owl:onProperty rdf:resource="https://w3id.org/sulo/isFeatureOf"/>
              <owl:someValuesFrom rdf:resource="Tissue"/>
            </owl:Restriction>
          </owl:intersectionOf>
        </owl:Class>
      </owl:someValuesFrom>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="https://w3id.org/sulo/hasParticipant"/>
      <owl:someValuesFrom>
        <owl:Class>
          <owl:intersectionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/ontostart/pro/InstrumentRole"/>
            <owl:Restriction>
              <owl:onProperty rdf:resource="https://w3id.org/sulo/isFeatureOf"/>
              <owl:someValuesFrom rdf:resource="BiopsyNeedle"/>
            </owl:Restriction>
          </owl:intersectionOf>
        </owl:Class>
      </owl:someValuesFrom>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="https://w3id.org/sulo/hasParticipant"/>
      <owl:someValuesFrom>
        <owl:Class>
          <owl:intersectionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/ontostart/pro/LocationRole"/>
            <owl:Restriction>
              <owl:onProperty rdf:resource="https://w3id.org/sulo/isFeatureOf"/>
              <owl:someValuesFrom rdf:resource="Breast"/>
            </owl:Restriction>
          </owl:intersectionOf>
        </owl:Class>
      </owl:someValuesFrom>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="https://w3id.org/sulo/hasParticipant"/>
      <owl:someValuesFrom>
        <owl:Class>
          <owl:intersectionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="SubjectOfCareRole"/>
            <owl:Restriction>
              <owl:onProperty rdf:resource="https://w3id.org/sulo/isFeatureOf"/>
              <owl:someValuesFrom rdf:resource="Person"/>
            </owl:Restriction>
          </owl:intersectionOf>
        </owl:Class>
      </owl:someValuesFrom>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:label xml:lang="en">core needle biopsy of breast</rdfs:label>
</owl:Class>

<owl:Class rdf:about="Person">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/SpatialObject"/>
  <rdfs:label xml:lang="en">person</rdfs:label>
</owl:Class>

<owl:Class rdf:about="RadiologistRole">
  <rdfs:subClassOf rdf:resource="PhysicianRole"/>
  <rdfs:label xml:lang="en">radiologist role</rdfs:label>
</owl:Class>

<owl:Class rdf:about="Tissue">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/SpatialObject"/>
  <rdfs:label xml:lang="en">tissue</rdfs:label>
</owl:Class>

<owl:Class rdf:about="BiopsyNeedle">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/SpatialObject"/>
  <rdfs:label xml:lang="en">biopsy needle</rdfs:label>
</owl:Class>

<owl:Class rdf:about="Breast">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/SpatialObject"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="https://w3id.org/sulo/SpatialObject"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="https://w3id.org/sulo/hasDirectPart"/>
          <owl:someValuesFrom rdf:resource="Nipple"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="https://w3id.org/sulo/hasDirectPart"/>
          <owl:someValuesFrom rdf:resource="MammaryGland"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="https://w3id.org/sulo/hasDirectPart"/>
          <owl:someValuesFrom rdf:resource="AdiposeTissue"/>
        </owl:Restriction>
        <owl:Restriction>
          <owl:onProperty rdf:resource="https://w3id.org/sulo/hasDirectPart"/>
          <owl:someValuesFrom rdf:resource="SkinOfBreast"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="https://w3id.org/sulo/hasDirectPart"/>
      <owl:onClass rdf:resource="Nipple"/>
      <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="https://w3id.org/sulo/hasDirectPart"/>
      <owl:allValuesFrom>
        <owl:Class>
          <owl:unionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="Nipple"/>
            <rdf:Description rdf:about="MammaryGland"/>
            <rdf:Description rdf:about="AdiposeTissue"/>
            <rdf:Description rdf:about="SkinOfBreast"/>
          </owl:unionOf>
        </owl:Class>
      </owl:allValuesFrom>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:label xml:lang="en">breast</rdfs:label>
</owl:Class>

<owl:Class rdf:about="SubjectOfCareRole">
  <rdfs:subClassOf rdf:resource="https://w3id.org/ontostart/pro/PatientRole"/>
  <rdfs:label xml:lang="en">subject-of-care role</rdfs:label>
</owl:Class>

<owl:Class rdf:about="PhysicianRole">
  <rdfs:subClassOf rdf:resource="CareProviderRole"/>
  <rdfs:label xml:lang="en">physician role</rdfs:label>
</owl:Class>

<owl:Class rdf:about="Nipple">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/SpatialObject"/>
  <rdfs:label xml:lang="en">nipple</rdfs:label>
</owl:Class>

<owl:Class rdf:about="MammaryGland">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/SpatialObject"/>
  <rdfs:label xml:lang="en">mammary gland</rdfs:label>
</owl:Class>

<owl:Class rdf:about="AdiposeTissue">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/SpatialObject"/>
  <rdfs:label xml:lang="en">adipose tissue</rdfs:label>
</owl:Class>

<owl:Class rdf:about="SkinOfBreast">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/SpatialObject"/>
  <rdfs:label xml:lang="en">skin of breast</rdfs:label>
</owl:Class>

<owl:Class rdf:about="CareProviderRole">
  <rdfs:subClassOf rdf:resource="https://w3id.org/ontostart/pro/AgentRole"/>
  <rdfs:label xml:lang="en">care-provider role</rdfs:label>
</owl:Class>

<owl:Class rdf:about="SCT_HistopathologyTest">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Process"/>
  <rdfs:label xml:lang="en">histopathology test</rdfs:label>
</owl:Class>

<owl:Class rdf:about="SCT_NeoadjuvantAntineoplasticChemotherapy">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Process"/>
  <rdfs:label xml:lang="en">neoadjuvant antineoplastic chemotherapy</rdfs:label>
</owl:Class>

<owl:Class rdf:about="SCT_LumpectomyOfLeftBreast">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Process"/>
  <rdfs:label xml:lang="en">lumpectomy of left breast</rdfs:label>
</owl:Class>

<owl:Class rdf:about="SCT_FollowUpVisit">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Process"/>
  <rdfs:subClassOf rdf:resource="https://w3id.org/ontostart/pro/DevelopmentalProcess"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="https://w3id.org/sulo/hasParticipant"/>
      <owl:someValuesFrom>
        <owl:Class>
          <owl:intersectionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="GynecologistRole"/>
            <owl:Restriction>
              <owl:onProperty rdf:resource="https://w3id.org/sulo/isFeatureOf"/>
              <owl:someValuesFrom rdf:resource="Person"/>
            </owl:Restriction>
          </owl:intersectionOf>
        </owl:Class>
      </owl:someValuesFrom>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="https://w3id.org/sulo/hasParticipant"/>
      <owl:someValuesFrom>
        <owl:Class>
          <owl:intersectionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="SubjectOfCareRole"/>
            <owl:Restriction>
              <owl:onProperty rdf:resource="https://w3id.org/sulo/isFeatureOf"/>
              <owl:someValuesFrom rdf:resource="Person"/>
            </owl:Restriction>
          </owl:intersectionOf>
        </owl:Class>
      </owl:someValuesFrom>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:label xml:lang="en">follow-up visit</rdfs:label>
</owl:Class>

<owl:Class rdf:about="GynecologistRole">
  <rdfs:subClassOf rdf:resource="PhysicianRole"/>
  <rdfs:label xml:lang="en">gynecologist role</rdfs:label>
</owl:Class>

<owl:Class rdf:about="SpecimenRole">
  <rdfs:subClassOf rdf:resource="https://w3id.org/ontostart/pro/PatientRole"/>
  <rdfs:label xml:lang="en">specimen role</rdfs:label>
</owl:Class>

<owl:Class rdf:about="SpecimenProducingProcedure">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Process"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="https://w3id.org/ontostart/pro/TransformationProcess"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="https://w3id.org/sulo/hasParticipant"/>
          <owl:someValuesFrom>
            <owl:Class>
              <owl:intersectionOf rdf:parseType="Collection">
                <rdf:Description rdf:about="https://w3id.org/ontostart/pro/EmergingRole"/>
                <owl:Restriction>
                  <owl:onProperty rdf:resource="https://w3id.org/sulo/isFeatureOf"/>
                  <owl:someValuesFrom>
                    <owl:Class>
                      <owl:intersectionOf rdf:parseType="Collection">
                        <rdf:Description rdf:about="Tissue"/>
                        <owl:Restriction>
                          <owl:onProperty rdf:resource="https://w3id.org/sulo/hasFeature"/>
                          <owl:someValuesFrom rdf:resource="SpecimenRole"/>
                        </owl:Restriction>
                      </owl:intersectionOf>
                    </owl:Class>
                  </owl:someValuesFrom>
                </owl:Restriction>
              </owl:intersectionOf>
            </owl:Class>
          </owl:someValuesFrom>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
  <rdfs:label xml:lang="en">specimen-producing procedure</rdfs:label>
</owl:Class>

<owl:Class rdf:about="SystolicBloodPressure">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Quality"/>
  <rdfs:label xml:lang="en">systolic blood pressure</rdfs:label>
</owl:Class>

<owl:Class rdf:about="MmHgUnit">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Unit"/>
  <rdfs:label xml:lang="en">mmHg</rdfs:label>
</owl:Class>

<owl:Class rdf:about="BPMeasurement">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Quantity"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="https://w3id.org/sulo/refersTo"/>
      <owl:someValuesFrom rdf:resource="SystolicBloodPressure"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="https://w3id.org/sulo/hasPart"/>
      <owl:someValuesFrom rdf:resource="MmHgUnit"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="https://w3id.org/sulo/hasValue"/>
      <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:label xml:lang="en">systolic blood pressure measurement</rdfs:label>
</owl:Class>

<owl:Class rdf:about="HypertensiveReading">
  <rdfs:subClassOf rdf:resource="BPMeasurement"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="BPMeasurement"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="https://w3id.org/sulo/hasValue"/>
          <owl:someValuesFrom>
            <rdfs:Datatype>
              <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
              <owl:withRestrictions>
                <rdf:Description>
                  <rdf:first>
                    <rdf:Description>
                      <xsd:minInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">140</xsd:minInclusive>
                    </rdf:Description>
                  </rdf:first>
                  <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                </rdf:Description>
              </owl:withRestrictions>
            </rdfs:Datatype>
          </owl:someValuesFrom>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
  <rdfs:label xml:lang="en">hypertensive reading</rdfs:label>
</owl:Class>

<owl:Class rdf:about="TumourGrade">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Quality"/>
  <rdfs:label xml:lang="en">tumour grade</rdfs:label>
</owl:Class>

<owl:Class rdf:about="TumourGrade1">
  <rdfs:subClassOf rdf:resource="TumourGrade"/>
  <rdfs:label xml:lang="en">grade 1</rdfs:label>
</owl:Class>

<owl:Class rdf:about="TumourGrade2">
  <rdfs:subClassOf rdf:resource="TumourGrade"/>
  <rdfs:label xml:lang="en">grade 2</rdfs:label>
</owl:Class>

<owl:Class rdf:about="TumourGrade3">
  <rdfs:subClassOf rdf:resource="TumourGrade"/>
  <rdfs:label xml:lang="en">grade 3</rdfs:label>
</owl:Class>

<owl:Class rdf:about="IntermediateOrHighGradeTumour">
  <rdfs:subClassOf rdf:resource="Tissue"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="Tissue"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="https://w3id.org/sulo/hasFeature"/>
          <owl:someValuesFrom>
            <owl:Class>
              <owl:unionOf rdf:parseType="Collection">
                <rdf:Description rdf:about="TumourGrade2"/>
                <rdf:Description rdf:about="TumourGrade3"/>
              </owl:unionOf>
            </owl:Class>
          </owl:someValuesFrom>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
  <rdfs:label xml:lang="en">intermediate or high grade tumour</rdfs:label>
</owl:Class>

<owl:Class rdf:about="ERPositive">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Quality"/>
  <owl:disjointWith rdf:resource="ERNegative"/>
  <rdfs:label xml:lang="en">ER positive</rdfs:label>
</owl:Class>

<owl:Class rdf:about="ERNegative">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Quality"/>
  <rdfs:label xml:lang="en">ER negative</rdfs:label>
</owl:Class>

<owl:Class rdf:about="PRPositive">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Quality"/>
  <owl:disjointWith rdf:resource="PRNegative"/>
  <rdfs:label xml:lang="en">PR positive</rdfs:label>
</owl:Class>

<owl:Class rdf:about="PRNegative">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Quality"/>
  <rdfs:label xml:lang="en">PR negative</rdfs:label>
</owl:Class>

<owl:Class rdf:about="HER2Positive">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Quality"/>
  <owl:disjointWith rdf:resource="HER2Negative"/>
  <rdfs:label xml:lang="en">HER2 positive</rdfs:label>
</owl:Class>

<owl:Class rdf:about="HER2Negative">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Quality"/>
  <rdfs:label xml:lang="en">HER2 negative</rdfs:label>
</owl:Class>

<owl:Class rdf:about="HormoneReceptorPositive">
  <rdfs:subClassOf rdf:resource="Tissue"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="Tissue"/>
        <owl:Class>
          <owl:unionOf rdf:parseType="Collection">
            <owl:Restriction>
              <owl:onProperty rdf:resource="https://w3id.org/sulo/hasFeature"/>
              <owl:someValuesFrom rdf:resource="ERPositive"/>
            </owl:Restriction>
            <owl:Restriction>
              <owl:onProperty rdf:resource="https://w3id.org/sulo/hasFeature"/>
              <owl:someValuesFrom rdf:resource="PRPositive"/>
            </owl:Restriction>
          </owl:unionOf>
        </owl:Class>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
  <rdfs:label xml:lang="en">hormone-receptor positive specimen</rdfs:label>
</owl:Class>

<owl:Class rdf:about="Tumour">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/SpatialObject"/>
  <rdfs:label xml:lang="en">tumour</rdfs:label>
</owl:Class>

<owl:Class rdf:about="LocalisedBreastTumour">
  <rdfs:subClassOf rdf:resource="Tumour"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="Tumour"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="https://w3id.org/sulo/isIn"/>
          <owl:someValuesFrom rdf:resource="Breast"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
  <rdfs:label xml:lang="en">localised breast tumour</rdfs:label>
</owl:Class>

<owl:Class rdf:about="BreastCancer">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Process"/>
  <rdfs:label xml:lang="en">breast cancer</rdfs:label>
</owl:Class>

<owl:Class rdf:about="InvasiveCarcinomaOfBreast">
  <rdfs:subClassOf rdf:resource="BreastCancer"/>
  <rdfs:label xml:lang="en">invasive carcinoma of breast</rdfs:label>
</owl:Class>

<owl:Class rdf:about="DiagnosisStatement">
  <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/InformationObject"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="https://w3id.org/sulo/refersTo"/>
      <owl:someValuesFrom rdf:resource="BreastCancer"/>
