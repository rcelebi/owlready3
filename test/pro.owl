    <rdf:rest rdf:nodeID="n2dae7800efde462e916f6301ae24d498b3"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2dae7800efde462e916f6301ae24d498b9">
    <rdf:first rdf:resource="https://w3id.org/ontostart/pro/ContainmentRole"/>
